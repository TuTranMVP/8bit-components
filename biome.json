{
  "$schema": "https://biomejs.dev/schemas/2.5.5/schema.json",
  "vcs": { "enabled": true, "clientKind": "git", "useIgnoreFile": true },
  "files": {
    "includes": [
      "**",
      "!fonts/**",
      "!demo.html",
      "!docs.html",
      "!index.html",
      "!docs.js",
      "!pnpm-lock.yaml",
      "!*.min.css",
      "!*.min.js",
      "!components.json",
      "!llms.txt",
      "!llms-full.txt",
      "!examples/**",
      "!.claude/**",
      "!.codex/**",
      "!.agents/**"
    ]
  },
  "formatter": {
    "enabled": true,
    "indentStyle": "space",
    "indentWidth": 2,
    "lineWidth": 100
  },
  "linter": {
    "enabled": true,
    "rules": { "preset": "none" }
  },
  "css": {
    "formatter": { "enabled": false },
    "linter": { "enabled": false }
  },
  "javascript": {
    "formatter": { "quoteStyle": "double" }
  }
}
